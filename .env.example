# Notion integration secret for the Recipe Logbook sync.
# Used ONLY by the Netlify serverless function (server-side) — never exposed to the browser.
#
# Local dev:  copy this file to `.env` and fill in the token, then run `netlify dev`.
# Production: set NOTION_TOKEN in Netlify → Site settings → Environment variables.
#
# The integration behind this token must be shared with the Coffee Recipe Logbook database.
NOTION_TOKEN=

# Optional: override the Logbook database id (defaults to the project's Logbook).
# NOTION_LOGBOOK_DB_ID=e746a40f6a324aff98cabb8d72fbe8ae
